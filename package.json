{
  "name": "CommentZ",
  "repository": "https://github.com/Parsa-1145/CommentZ.git",
  "displayName": "CommentZ",
  "description": "Simple styled commentz",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "publisher": "PZ",
  "icon": "assets/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "CommentZ",
      "properties": {
        "commentZ.styles.boxed.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for boxed commentz"
        },
        "commentZ.styles.boxed.minPadding": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "description": "Minimum padding for boxed commentz"
        },
        "commentZ.styles.bordered.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for bordered commentz"
        },
        "commentZ.styles.bordered.minPadding": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "description": "Minimum padding for bordered commentz"
        },
        "commentZ.styles.bordered.leftMargin": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "description": "leftMargin for bordered commentz"
        },
        "commentZ.styles.line.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for line commentz"
        },
        "commentZ.styles.line.minPadding": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "description": "Minimum padding for line commentz"
        }
      }
  },
  "submenus": [
    {
      "id": "commentZ.convertToComment",
      "label": "Make Comment"
    }
  ],
  "menus": {
      "editor/context": [
        {
          "submenu": "commentZ.convertToComment",
          "group": "1_modification",
          "when": "editorHasSelection && (resourceLangId == python || resourceLangId == c || resourceLangId == cpp || resourceLangId == javascript || resourceLangId == typescript)"
        }
      ],
      "commentZ.convertToComment": [
        {
          "command": "commentZ.convertToBoxed"
        },
        {
          "command": "commentZ.convertToBordered"
        },
        {
          "command": "commentZ.convertToHeader"
        }
      ]
    },
    "commands": [
      {
        "command": "commentZ.convertToBoxed",
        "title": "Convert To Boxed Comment",
        "shortTitle": "Boxed comment"
      },
      {
        "command": "commentZ.convertToBordered",
        "title": "Convert To Bordered Comment",
        "shortTitle": "Bordered Comment"
      },
      {
        "command": "commentZ.convertToHeader",
        "title": "Convert To Header Comment",
        "shortTitle": "Header Comment"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
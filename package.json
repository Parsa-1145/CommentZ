{
  "name": "styled-commenter",
  "displayName": "Styled Commenter",
  "description": "Simple styled comments",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Styled Commenter",
      "properties": {
        "styled-commenter.styles.boxed.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for boxed comments"
        },
        "styled-commenter.styles.boxed.minPadding": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "description": "Minimum padding for boxed comments"
        },
        "styled-commenter.styles.bordered.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for bordered comments"
        },
        "styled-commenter.styles.bordered.minPadding": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "description": "Minimum padding for bordered comments"
        },
        "styled-commenter.styles.bordered.leftMargin": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "description": "leftMargin for bordered comments"
        },
        "styled-commenter.styles.line.defaultSize": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Default size for line comments"
        },
        "styled-commenter.styles.line.minPadding": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "description": "Minimum padding for line comments"
        }
      }
  },
  "submenus": [
    {
      "id": "styled-commenter.convertToComment",
      "label": "Convert To Comment"
    }
  ],
  "menus": {
      "editor/context": [
        {
          "submenu": "styled-commenter.convertToComment",
          "group": "1_modification",
          "when": "editorHasSelection && (resourceLangId == python || resourceLangId == c || resourceLangId == cpp || resourceLangId == javascript || resourceLangId == typescript)"
        }
      ],
      "styled-commenter.convertToComment": [
        {
          "command": "styled-commenter.convertToBoxed"
        },
        {
          "command": "styled-commenter.convertToBordered"
        },
        {
          "command": "styled-commenter.convertToHeader"
        }
      ]
    },
    "commands": [
      {
        "command": "styled-commenter.convertToBoxed",
        "title": "Convert To Boxed Comment",
        "shortTitle": "Boxed comment"
      },
      {
        "command": "styled-commenter.convertToBordered",
        "title": "Convert To Bordered Comment",
        "shortTitle": "Bordered Comment"
      },
      {
        "command": "styled-commenter.convertToHeader",
        "title": "Convert To Header Comment",
        "shortTitle": "Header Comment"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}